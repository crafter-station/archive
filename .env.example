# Neon/Postgres connection string used by Drizzle and the app.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# OpenAI key used by the scheduled Trigger.dev log agent.
OPENAI_API_KEY="sk-proj_..."

# Vercel Blob token used to store WhatsApp media attachments.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Shared secret expected in the x-webhook-signature header for WhatsApp webhooks.
WHATSAPP_WEBHOOK_SECRET="replace-with-a-long-random-secret"
